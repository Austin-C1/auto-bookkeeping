# BlackCat V1 production environment example.
#
# Usage:
# 1. Copy this file to .env
#    cp docker-compose.prod.env.example .env
# 2. Replace the placeholder values, especially security secrets.
# 3. Run:
#    docker-compose -f docker-compose.prod.yml up -d

# ============================================
# Database configuration
# ============================================
DB_URL=jdbc:mysql://mysql:3306/blackcat_v1?useSSL=false&serverTimezone=UTC&characterEncoding=utf8&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_database_password_here

# ============================================
# Spring profile
# ============================================
SPRING_PROFILES_ACTIVE=prod

# ============================================
# Server port
# ============================================
SERVER_PORT=80

# ============================================
# MySQL port
# ============================================
# Optional external MySQL port. Defaults to 3307 to avoid conflicts with a local MySQL instance.
MYSQL_PORT=3307

# ============================================
# Security configuration
# ============================================
# These values must be changed before production use.
#
# JWT secret key for generating and validating JWT tokens.
# Generate with: openssl rand -hex 64
JWT_SECRET=change-me-in-production
#
# Admin password reset key.
# Generate with: openssl rand -hex 32
ADMIN_RESET_PASSWORD_KEY=change-me-in-production
#
# Encryption key for stored private keys and API keys.
# Generate with: openssl rand -hex 32
CRYPTO_SECRET_KEY=change-me-in-production

# ============================================
# Logging
# ============================================
# Optional settings. Uncomment to override defaults.
# LOG_LEVEL_ROOT=WARN
# LOG_LEVEL_APP=INFO
